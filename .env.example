# ══════════════════════════════════════════════════════════════════════════════
# ASM Platform — environment configuration
#
# Quick start (Docker — Full Stack):
#   cp .env.example .env
#   # Set ANTHROPIC_API_KEY (or OPENAI_API_KEY) and ADMIN_PASSWORD below, then:
#   docker compose up -d
#   # Open http://localhost:5174
#
# Quick start (Local — Developer Mode):
#   make dev-infra
#   # In separate terminals:
#   make server
#   make worker
#   make frontend
#   # Open http://localhost:5173
# ══════════════════════════════════════════════════════════════════════════════

# ── Required: set at least one LLM key and an admin password ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ADMIN_PASSWORD=change-me

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose overrides this automatically. Only set for local dev.
DATABASE_URL=postgres://asm:asm_secret@localhost:5432/asm?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=asm-workers

# Executor mode: direct (no Temporal) | temporal
EXECUTOR_MODE=direct

# LLM Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model (supports template vars in workflow YAML)
DEFAULT_MODEL=claude-sonnet-4-6

# ── Ollama (local LLM — no API key required) ────────────────────────────────
# Set OLLAMA_URL to enable the "ollama" provider.
# The platform appends /v1/chat/completions to reach the OpenAI-compatible API.
# Switch to Ollama by setting LLM_PROVIDER=ollama (or per-agent via model field).
#
# OLLAMA_URL=http://mintbox:11434
# OLLAMA_MODEL=llama3.2
#
# Tip: to use Ollama only for specific agents, keep LLM_PROVIDER=anthropic and
# set the model field on individual agents in the workflow YAML:
#   agents:
#     - name: fast-classifier
#       model: llama3.2           # routed to Ollama when OLLAMA_URL is set
#
# Tool-calling support by model size:
#   llama3.2 3B  — text output only; tool calls unreliable (use script states instead)
#   llama3.2 11B — tool calling supported
#   llama3.1 8B  — tool calling supported

# Server
# Port the Go API server listens on inside Docker (not exposed externally by default).
PORT=8080
# Port the frontend Nginx container listens on (exposed to the host).
# Change to e.g. 8081 if port 80 is taken.
FRONTEND_PORT=80
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── MCP Tool Servers ────────────────────────────────────────────────────────
# Declare MCP server URLs here as environment variables.
# Reference them in workflow YAML agent config using Go template syntax:
#
#   agents:
#     - name: validator
#       config:
#         mcp_servers: "{{ env.MCP_VALIDATE_URL }}"
#
# Multiple servers (comma-separated):
#         mcp_servers: "{{ env.MCP_VALIDATE_URL }},{{ env.MCP_ENRICH_URL }}"
#
# The YAML loader expands {{ env.VAR }} before the config reaches the executor.
# Never hardcode MCP server URLs — always reference them via env vars.
#
# MCP_VALIDATE_URL=http://localhost:3001
# MCP_ENRICH_URL=http://localhost:3002
# MCP_PAYMENT_URL=http://localhost:3003

# Demo MCP Servers
# MCP_GLEIF_URL=http://localhost:8091
# MCP_EXCHANGE_URL=http://localhost:8092
# MCP_OPENFIGI_URL=http://localhost:8093
# OPENFIGI_API_KEY=

# MCP_WEATHER_URL=http://localhost:8094
# OPENWEATHERMAP_API_KEY=
# MCP_SOLAR_URL=http://localhost:8095
# ── Specialist Workers ───────────────────────────────────────────────────────
# Each specialist worker binary polls its own task queue.
# The queue name is declared in the workflow YAML under agent.task_queue.
# Run with: SPECIALIST_TASK_QUEUE=validate-workers go run ./cmd/specialist-worker
#
# SPECIALIST_TASK_QUEUE=specialist-workers

# ── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT access tokens (HS256). Change this in production.
# Minimum recommended length: 32 random bytes (base64-encoded).
JWT_SECRET=dev-insecure-secret-change-in-prod

# Admin user seeded on first startup when no users exist yet.
# Set ADMIN_PASSWORD to a non-empty string to enable auto-seeding.
# The admin account is created with role "admin".
# Leave ADMIN_PASSWORD empty to skip seeding (manage users manually).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Token lifetimes (hardcoded, shown here for reference):
#   Access token TTL  : 15 minutes  (JWT, stateless)
#   Refresh token TTL : 7 days      (opaque, stored as SHA-256 hash in DB)
#
# Token rotation: every /auth/refresh call revokes the used token and issues
# a fresh pair. All tokens are revoked on /auth/logout.

# ── Telemetry ────────────────────────────────────────────────────────────────
# Opt-in anonymous install beacon. Used to measure open-source adoption.
# No PII or project data is sent. Only OS/Arch on server startup.
ENABLE_TELEMETRY=false

